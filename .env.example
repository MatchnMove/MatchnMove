# Core app
# If your Railway database service is not named "Postgres", change the reference below.
DATABASE_URL=${{Postgres.DATABASE_URL}}
NEXTAUTH_URL=https://your-service.up.railway.app
NEXT_PUBLIC_APP_URL=https://your-service.up.railway.app
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# Optional mover Google sign-in
# Use the Web client ID from Google Cloud Console.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Optional server-side override. Leave blank unless you need to verify against a different Web client ID.
GOOGLE_CLIENT_ID=

# Optional Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional mover verification integrations
# Required for automatic NZBN Register lookups. Without this, valid NZBNs go to manual review.
NZBN_API_SUBSCRIPTION_KEY=
NZBN_API_BASE_URL=https://api.business.govt.nz/gateway/nzbn/v5
MOVER_VERIFICATION_ADMIN_TOKEN=replace-with-a-long-random-secret

# Optional voice/transcription integrations
ELEVENLABS_API_KEY=
N8N_WEBHOOK_URL=

# Optional file storage
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_PUBLIC_URL=

# Email routing
CONTACT_TO_EMAIL=contact@matchnmove.co.nz
CONTACT_FROM_EMAIL=contact@matchnmove.co.nz
SUPPORT_EMAIL=support@matchnmove.co.nz
DEFAULT_FROM_EMAIL=info@matchnmove.co.nz
INFO_FROM_EMAIL=info@matchnmove.co.nz
NO_REPLY_FROM_EMAIL=no-reply@matchnmove.co.nz
AUTH_FROM_EMAIL=no-reply@matchnmove.co.nz
FEEDBACK_FROM_EMAIL=feedback@matchnmove.co.nz
REVIEW_FROM_EMAIL=feedback@matchnmove.co.nz

# SMTP
# For a single Google Workspace mailbox, use smtp.gmail.com with an app password.
# For higher-volume Workspace sending, configure Google Admin SMTP relay and use smtp-relay.gmail.com.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_NAME=matchnmove.co.nz
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
EMAIL_FORCE_SMTP_USER_FROM=true
EMAIL_MAX_ATTEMPTS=5
EMAIL_RETRY_BASE_MS=60000
EMAIL_RETRY_MAX_MS=1800000
EMAIL_SENDING_STALE_MS=600000
EMAIL_QUEUE_SECRET=replace-with-a-long-random-secret
BACKGROUND_JOBS_ENABLED=true
BACKGROUND_JOBS_INTERVAL_MS=60000
BACKGROUND_JOBS_PROCESS_LIMIT=50

# Public website email addresses
NEXT_PUBLIC_SUPPORT_EMAIL=support@matchnmove.co.nz
NEXT_PUBLIC_INFO_EMAIL=info@matchnmove.co.nz
NEXT_PUBLIC_CONTACT_EMAIL=contact@matchnmove.co.nz
NEXT_PUBLIC_PARTNERS_EMAIL=partners@matchnmove.co.nz
NEXT_PUBLIC_FEEDBACK_EMAIL=feedback@matchnmove.co.nz
NEXT_PUBLIC_PRIVACY_EMAIL=support@matchnmove.co.nz
NEXT_PUBLIC_NO_REPLY_EMAIL=no-reply@matchnmove.co.nz
