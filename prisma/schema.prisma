generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  MOVER
  ADMIN
}

enum LeadStatus {
  NEW
  NOTIFIED
  VIEWED
  PURCHASED
  CONTACTED
  WON
  LOST
  ARCHIVED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum AuthTokenType {
  VERIFY_EMAIL
  RESET_PASSWORD
}

enum ReviewModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id              String      @id @default(cuid())
  name            String?
  email           String      @unique
  passwordHash    String
  emailVerifiedAt DateTime?
  role            UserRole    @default(MOVER)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  moverCompany    MoverCompany?
  authTokens      AuthToken[]
}

model MoverCompany {
  id                       String               @id @default(cuid())
  userId                   String               @unique
  stripeCustomerId         String?              @unique
  companyName              String
  businessDescription      String?
  nzbn                     String?
  yearsOperating           Int?
  logoUrl                  String?
  serviceAreas             String[]
  status                   String               @default("ACTIVE")
  contactPerson            String?
  phone                    String?
  baseLeadPrice            Int                  @default(2000)
  averageRating            Float                @default(0)
  totalReviewCount         Int                  @default(0)
  fiveStarCount            Int                  @default(0)
  fourStarCount            Int                  @default(0)
  threeStarCount           Int                  @default(0)
  twoStarCount             Int                  @default(0)
  oneStarCount             Int                  @default(0)
  communicationAverage     Float                @default(0)
  punctualityAverage       Float                @default(0)
  careOfBelongingsAverage  Float                @default(0)
  professionalismAverage   Float                @default(0)
  valueForMoneyAverage     Float                @default(0)
  recommendationRate       Float                @default(0)
  leaderboardEligible      Boolean              @default(false)
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  user                     User                 @relation(fields: [userId], references: [id])
  documents                MoverDocument[]
  leads                    Lead[]
  reviews                  Review[]
  reviewSurveyInvites      ReviewSurveyInvite[]

  @@index([status, updatedAt])
}

model MoverDocument {
  id             String       @id @default(cuid())
  moverCompanyId String
  type           String
  fileName       String?
  mimeType       String?
  fileSize       Int?
  fileUrl        String
  createdAt      DateTime     @default(now())
  moverCompany   MoverCompany @relation(fields: [moverCompanyId], references: [id])

  @@index([moverCompanyId, createdAt])
}

model QuoteRequest {
  id                 String    @id @default(cuid())
  name               String
  email              String
  phone              String
  movingWhat         String?
  fromPropertyType   String
  toPropertyType     String
  bedrooms           String
  fromAddress        String
  fromCity           String
  fromRegion         String
  fromPostcode       String
  fromCountry        String
  toAddress          String
  toCity             String
  toRegion           String
  toPostcode         String
  toCountry          String
  moveDate           DateTime?
  dateFlexible       Boolean   @default(false)
  transcriptRaw      Json?
  transcriptFields   Json?
  transcriptionState String?
  createdAt          DateTime  @default(now())
  leads              Lead[]

  @@index([createdAt])
}

model Lead {
  id               String             @id @default(cuid())
  quoteRequestId   String
  moverCompanyId   String
  status           LeadStatus         @default(NEW)
  price            Int
  purchasedAt      DateTime?
  createdAt        DateTime           @default(now())
  quoteRequest     QuoteRequest       @relation(fields: [quoteRequestId], references: [id])
  moverCompany     MoverCompany       @relation(fields: [moverCompanyId], references: [id])
  payment          Payment?
  auditLogs        AuditLog[]
  review           Review?
  reviewSurveyInvite ReviewSurveyInvite?

  @@index([quoteRequestId])
  @@index([moverCompanyId, createdAt])
  @@index([moverCompanyId, status])
}

model Review {
  id                    String                 @id @default(cuid())
  moverCompanyId        String
  leadId                String                 @unique
  reviewSurveyInviteId  String?                @unique
  overallRating         Int
  communicationRating   Int?
  punctualityRating     Int?
  careOfBelongingsRating Int?
  professionalismRating Int?
  valueForMoneyRating   Int?
  writtenReview         String?                @db.Text
  recommendMover        Boolean?
  showReviewerName      Boolean                @default(true)
  moderationStatus      ReviewModerationStatus @default(PENDING)
  isPublic              Boolean                @default(false)
  submittedAt           DateTime               @default(now())
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  moverCompany          MoverCompany           @relation(fields: [moverCompanyId], references: [id], onDelete: Cascade)
  lead                  Lead                   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  reviewSurveyInvite    ReviewSurveyInvite?    @relation(fields: [reviewSurveyInviteId], references: [id], onDelete: SetNull)

  @@index([moverCompanyId, moderationStatus, isPublic, submittedAt])
}

model ReviewSurveyInvite {
  id             String    @id @default(cuid())
  moverCompanyId String
  leadId         String    @unique
  tokenHash      String    @unique
  customerName   String
  customerEmail  String
  expiresAt      DateTime
  sentAt         DateTime?
  consumedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  moverCompany   MoverCompany @relation(fields: [moverCompanyId], references: [id], onDelete: Cascade)
  lead           Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  review         Review?

  @@index([moverCompanyId, expiresAt])
}

model PricingRule {
  id             String  @id @default(cuid())
  name           String
  baseLeadPrice   Int
  bedroomModifier Int    @default(1000)
  urgentModifier  Int    @default(2000)
  distanceModifier Int   @default(2000)
}

model Payment {
  id                    String        @id @default(cuid())
  leadId                String        @unique
  stripePaymentIntentId String?
  stripeCheckoutId      String?
  stripeChargeId        String?
  receiptUrl            String?
  amount                Int
  status                PaymentStatus @default(PENDING)
  createdAt             DateTime      @default(now())
  lead                  Lead          @relation(fields: [leadId], references: [id])

  @@index([status, createdAt])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  leadId    String
  action    String
  meta      Json?
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id])

  @@index([leadId, createdAt])
}

model AuthToken {
  id         String        @id @default(cuid())
  userId     String
  type       AuthTokenType
  tokenHash  String        @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

